{
  "name": "deepseek-monitor",
  "version": "1.0.0",
  "description": "DeepSeek 余额与用量监控 (Windows 托盘版) — DeepSeekMonitor 的 Windows 复刻",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "author": "chunqingjtr",
  "license": "MIT",
  "build": {
    "appId": "com.deepseek.monitor",
    "productName": "DeepSeek Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "deepseek.js",
      "store.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/whale.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DeepSeek Monitor",
      "installerIcon": "assets/whale.ico",
      "uninstallerIcon": "assets/whale.ico"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  }
}
